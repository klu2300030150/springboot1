{
  "info": {
    "name": "Backend Assignment Guardrails API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Create User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/users",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"alice\",\n  \"premium\": false\n}"
        }
      }
    },
    {
      "name": "Create Bot",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/bots",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"HelperBot\",\n  \"personaDescription\": \"Helpful and concise\"\n}"
        }
      }
    },
    {
      "name": "Create Post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/posts",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"USER\",\n  \"content\": \"Hello from the guardrails assignment\"\n}"
        }
      }
    },
    {
      "name": "Add Human Comment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/posts/1/comments",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"USER\",\n  \"content\": \"Human comment\"\n}"
        }
      }
    },
    {
      "name": "Add Bot Comment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/posts/1/comments",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"BOT\",\n  \"content\": \"Bot reply\"\n}"
        }
      }
    },
    {
      "name": "Add Nested Comment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/posts/1/comments",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorId\": 1,\n  \"authorType\": \"USER\",\n  \"parentCommentId\": 1,\n  \"content\": \"Nested human reply\"\n}"
        }
      }
    },
    {
      "name": "Like Post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/posts/1/like",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": 1\n}"
        }
      }
    }
  ]
}
